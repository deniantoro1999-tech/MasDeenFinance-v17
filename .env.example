# ═══════════════════════════════════════════════════════════════
# MasDeen Finance v17 — Environment Variables
# 
# Copy file ini ke `.env` dan isi dengan value sebenarnya.
# JANGAN commit .env ke Git (sudah ada di .gitignore).
# ═══════════════════════════════════════════════════════════════

# ─── Gemini AI (opsional) ──────────────────────────────────
# Dapatkan API key di: https://aistudio.google.com/app/apikey
# Kalau tidak diset, fitur MasDeen AI akan nonaktif (UI tetap
# muncul dengan pesan friendly "AI tidak tersedia")
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase (wajib) ──────────────────────────────────────
# Konfigurasi utama ada di firebase-applet-config.json, tapi
# kalau mau pakai env var juga bisa, nanti modifikasi firebase.ts

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
